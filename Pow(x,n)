class Solution {
public:
    double myPow(double x, int n) {
        // Use long long to safely handle INT_MIN (-2147483648) 
        // because negating it would overflow a standard 32-bit int.
        long long N = n;
        
        // Handle negative exponents: x^(-n) = (1/x)^n
        if (N < 0) {
            x = 1 / x;
            N = -N;
        }
        
        double result = 1.0;
        double current_product = x;
        
        // Binary Exponentiation logic
        while (N > 0) {
            // If the current power is odd, multiply the result by current_product
            if (N % 2 == 1) {
                result *= current_product;
            }
            // Square the base and halve the power
            current_product *= current_product;
            N /= 2;
        }
        
        return result;
    }
};
