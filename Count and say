#include <string>

using namespace std;

class Solution {
public:
    string countAndSay(int n) {
        // Base case
        if (n == 1) return "1";

        // Get the previous string recursively
        string prev = countAndSay(n - 1);
        string result = "";
        
        // Perform Run-Length Encoding on prev
        for (int i = 0; i < prev.length(); i++) {
            int count = 1;
            
            // Count consecutive identical characters
            while (i + 1 < prev.length() && prev[i] == prev[i + 1]) {
                count++;
                i++;
            }
            
            // Append the count followed by the character itself
            result += to_string(count) + prev[i];
        }

        return result;
    }
};
